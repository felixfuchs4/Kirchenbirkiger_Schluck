<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Anzeige.InfoscreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KirchenbirkigerSchluck.App.ViewModels.Anzeige"
             xmlns:verhalten="clr-namespace:KirchenbirkigerSchluck.App.Behaviors"
             xmlns:gemeinsam="clr-namespace:KirchenbirkigerSchluck.App.Views.Gemeinsam">
    <!--
        Datei:   InfoscreenView.xaml
        Zweck:   Rotierender Infoscreen (Nächste/Letzte Partie, Tabellen, Spielplan, Finalrunde)
        Bereich: Präsentation – Anzeige-Views
    -->
    <Grid Background="{StaticResource VerlaufAnzeigeHintergrund}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header-Leiste -->
        <Border Grid.Row="0"
                Background="{StaticResource VerlaufKopf}"
                Padding="56,26"
                BorderBrush="{StaticResource PinselTrennlinie}"
                BorderThickness="0,0,0,2">
            <StackPanel Orientation="Horizontal">
                <Border Width="6" Height="40"
                        Background="{StaticResource VerlaufAkzent}"
                        CornerRadius="3" Margin="0,0,20,0"
                        Effect="{StaticResource GlowGoldSanft}" />
                <TextBlock Text="{Binding FolienTitel}"
                           Style="{StaticResource UeberschriftAnzeigeStyle}"
                           HorizontalAlignment="Left" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Folien-Host: jeder Folienwechsel wird weich eingeblendet -->
        <Grid Grid.Row="1"
              verhalten:ScreenUebergangVerhalten.Ausloeser="{Binding AktuellerFolienTyp}">

            <!-- ════ Folie: Nächste Partie ════ -->
            <Grid Margin="80">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AktuellerFolienTyp}" Value="{x:Static vm:InfoFolienTyp.NaechstePartie}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Style="{StaticResource AnzeigeKarteStyle}" Padding="60,48"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Grid.IsSharedSizeScope="True">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding NaechstesSpielKontext}"
                                   Style="{StaticResource AnzeigeTextGedaempftStyle}" FontSize="24"
                                   HorizontalAlignment="Center" Margin="0,0,0,28" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="NpTeam" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="NpTeam" />
                            </Grid.ColumnDefinitions>
                            <gemeinsam:TeamAnzeige Grid.Column="0"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   LogoPfad="{Binding NaechstesTeam1Logo}"
                                                   TeamName="{Binding NaechstesTeam1}"
                                                   LogoGroesse="120" />
                            <Border Grid.Column="1" Background="{StaticResource VerlaufAkzent}"
                                    CornerRadius="{StaticResource RadiusPille}" Padding="22,8" Margin="40,0"
                                    VerticalAlignment="Center" Effect="{StaticResource GlowGoldSanft}">
                                <TextBlock Text="VS" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource PinselTextAufAkzent}" />
                            </Border>
                            <gemeinsam:TeamAnzeige Grid.Column="2"
                                                   VerticalAlignment="Center" HorizontalAlignment="Left"
                                                   LogoPfad="{Binding NaechstesTeam2Logo}"
                                                   TeamName="{Binding NaechstesTeam2}"
                                                   LogoGroesse="120" />
                        </Grid>
                        <TextBlock Text="Keine weiteren Spiele geplant" HorizontalAlignment="Center" Margin="0,24,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource AnzeigeTextGedaempftStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HatNaechstesSpiel}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ════ Folie: Letzte Partie ════ -->
            <Grid Margin="80">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AktuellerFolienTyp}" Value="{x:Static vm:InfoFolienTyp.LetztePartie}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Style="{StaticResource AnzeigeKarteStyle}" Padding="60,48"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Grid.IsSharedSizeScope="True">
                    <StackPanel HorizontalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="LpTeam" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="LpTeam" />
                            </Grid.ColumnDefinitions>
                            <gemeinsam:TeamAnzeige Grid.Column="0"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                   LogoPfad="{Binding LetztesTeam1Logo}"
                                                   TeamName="{Binding LetztesTeam1}"
                                                   LogoGroesse="110" />
                            <TextBlock Grid.Column="1" Text="{Binding LetztesErgebnis}"
                                       FontSize="64" FontWeight="Bold"
                                       Foreground="{StaticResource VerlaufAkzent}"
                                       Effect="{StaticResource GlowGoldSanft}" Margin="40,0" VerticalAlignment="Center" />
                            <gemeinsam:TeamAnzeige Grid.Column="2"
                                                   VerticalAlignment="Center" HorizontalAlignment="Left"
                                                   LogoPfad="{Binding LetztesTeam2Logo}"
                                                   TeamName="{Binding LetztesTeam2}"
                                                   LogoGroesse="110" />
                        </Grid>
                        <Border Style="{StaticResource ErgebnisPilleStyle}" Padding="28,10" Margin="0,32,0,0">
                            <TextBlock>
                                <Run Text="Sieger: " Foreground="{StaticResource PinselTextGedaempft}" FontSize="24" />
                                <Run Text="{Binding LetzterSieger}" Foreground="{StaticResource PinselAkzent}" FontSize="24" FontWeight="Bold" />
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ════ Folie: Gruppentabelle (bildschirmfüllend) ════ -->
            <Grid Margin="80,40">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AktuellerFolienTyp}" Value="{x:Static vm:InfoFolienTyp.GruppenTabelle}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Style="{StaticResource AnzeigeKarteStyle}" Padding="40,28">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0" Margin="16,0,16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Pl." Style="{StaticResource TabellenKopfTextStyle}" />
                            <TextBlock Grid.Column="1" Text="Team" Style="{StaticResource TabellenKopfTextStyle}" />
                            <TextBlock Grid.Column="2" Text="Sp." Style="{StaticResource TabellenKopfTextStyle}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="S." Style="{StaticResource TabellenKopfTextStyle}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="Duelle" Style="{StaticResource TabellenKopfTextStyle}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="5" Text="Pkt." Style="{StaticResource TabellenKopfTextStyle}" HorizontalAlignment="Center" />
                        </Grid>
                        <Border Grid.Row="1" Height="1" Background="{StaticResource PinselTrennlinie}" Margin="16,0,16,8" />

                        <!-- Zeilen füllen die verfügbare Höhe (UniformGrid) -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding AktuelleTabellenZeilen}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Columns="1" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AnzeigeZeileStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="100" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Platz, StringFormat='{}{0}.'}"
                                                       Foreground="{StaticResource PinselAkzent}" FontSize="26" FontWeight="Bold" VerticalAlignment="Center" />
                                            <Image Grid.Column="1" Source="{Binding LogoPfad, Converter={StaticResource PfadZuBitmap}}"
                                                   Width="40" Height="40" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"
                                                   Visibility="{Binding LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TeamName}" Style="{StaticResource AnzeigeTextStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <Border Background="{StaticResource PinselStechen}" CornerRadius="{StaticResource RadiusS}" Padding="8,2" Margin="12,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding StechenNoetig, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="STECHEN" Foreground="White" FontSize="12" FontWeight="Bold" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding Spiele}" Style="{StaticResource AnzeigeTextGedaempftStyle}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="4" Text="{Binding Siege}" Style="{StaticResource AnzeigeTextGedaempftStyle}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="5" Text="{Binding DuellDifferenz}" Style="{StaticResource AnzeigeTextGedaempftStyle}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="6" Text="{Binding Punkte}" Foreground="{StaticResource PinselAkzent}" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- ════ Folie: Spielplan ════ -->
            <Grid Margin="80,40">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AktuellerFolienTyp}" Value="{x:Static vm:InfoFolienTyp.Spielplan}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Style="{StaticResource AnzeigeKarteStyle}" Padding="40,28">
                    <!-- Lange Spielpläne scrollen automatisch durch (Auf/Ab mit Pausen) -->
                    <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                  verhalten:AutoScrollVerhalten.IstAktiv="True">
                        <ItemsControl ItemsSource="{Binding SpielplanZeilen}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AnzeigeZeileStyle}" Padding="18,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="64" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Nummer}" Foreground="{StaticResource PinselTextGedaempft}" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Team1}" Style="{StaticResource AnzeigeTextStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                                <Image Source="{Binding Team1LogoPfad, Converter={StaticResource PfadZuBitmap}}" Width="34" Height="34" Stretch="Uniform" Margin="12,0,0,0" VerticalAlignment="Center"
                                                       Visibility="{Binding Team1LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="–" Foreground="{StaticResource PinselTextGedaempft}" FontSize="22" Margin="18,0" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Image Source="{Binding Team2LogoPfad, Converter={StaticResource PfadZuBitmap}}" Width="34" Height="34" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"
                                                       Visibility="{Binding Team2LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                                                <TextBlock Text="{Binding Team2}" Style="{StaticResource AnzeigeTextStyle}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="4" Text="{Binding Runde}" Foreground="{StaticResource PinselTextGedaempft}" FontSize="18" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ════ Folie: Finalrunden-Baum ════ -->
            <Grid Margin="60,40">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AktuellerFolienTyp}" Value="{x:Static vm:InfoFolienTyp.Bracket}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Viewbox Stretch="Uniform">
                    <Grid Width="{Binding BracketBreite}" Height="{Binding BracketHoehe}">
                        <!-- Verbindungslinien (Ebene hinter den Karten):
                             durchgezogen = Siegerpfad (gold), gestrichelt = Platzierungspfad (gedämpft) -->
                        <ItemsControl ItemsSource="{Binding BracketLinien}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Polyline Points="{Binding Punkte}"
                                              Stroke="{StaticResource PinselAkzent}"
                                              StrokeThickness="2.5" Opacity="0.75">
                                        <Polyline.Style>
                                            <Style TargetType="Polyline">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Gestrichelt}" Value="True">
                                                        <Setter Property="StrokeDashArray" Value="5 3" />
                                                        <Setter Property="Opacity" Value="0.45" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Polyline.Style>
                                    </Polyline>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Spaltentitel -->
                        <ItemsControl ItemsSource="{Binding BracketTitel}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Width="{Binding Breite}"
                                               Foreground="{StaticResource PinselAkzent}"
                                               FontSize="22" FontWeight="Bold" TextAlignment="Center" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Knoten (Spiele) -->
                        <ItemsControl ItemsSource="{Binding BracketKnoten}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource AnzeigeKarteStyle}" Padding="16,10"
                                            Width="{Binding Breite}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Image Grid.Column="0" Source="{Binding Team1LogoPfad, Converter={StaticResource PfadZuBitmap}}" Width="26" Height="26" Stretch="Uniform" Margin="0,0,10,0"
                                                       Visibility="{Binding Team1LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Team1}" Foreground="{StaticResource PinselText}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                            <Border Height="1" Background="{StaticResource PinselTrennlinie}" Margin="0,2" />
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Image Grid.Column="0" Source="{Binding Team2LogoPfad, Converter={StaticResource PfadZuBitmap}}" Width="26" Height="26" Stretch="Uniform" Margin="0,0,10,0"
                                                       Visibility="{Binding Team2LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Team2}" Foreground="{StaticResource PinselText}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2" Text="{Binding Ergebnis}" Foreground="{StaticResource PinselAkzent}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Viewbox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
