<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Anzeige.MatchdayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:verhalten="clr-namespace:KirchenbirkigerSchluck.App.Behaviors"
             xmlns:gemeinsam="clr-namespace:KirchenbirkigerSchluck.App.Views.Gemeinsam">
    <!--
        Datei:   MatchdayView.xaml
        Zweck:   Live-Spielansicht mit Teamnamen, Gesamtstand und Duellliste
        Bereich: Präsentation – Anzeige-Views
    -->
    <UserControl.Resources>
        <!-- Score-Ziffer: pulst bei Wertänderung, glüht bei Stechen rot -->
        <Style x:Key="MatchScoreStyle" TargetType="TextBlock" BasedOn="{StaticResource ScoreTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IstStechen}" Value="True">
                    <Setter Property="Effect" Value="{StaticResource GlowRot}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource VerlaufAnzeigeHintergrund}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Score-Header -->
            <RowDefinition Height="*" />
            <!-- Duellliste -->
            <RowDefinition Height="Auto" />
            <!-- Versuch-Anzeige -->
        </Grid.RowDefinitions>

        <!-- ── Score-Header ────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource VerlaufKopf}"
                Padding="56,36"
                BorderBrush="{StaticResource PinselTrennlinie}"
                BorderThickness="0,0,0,2">
            <Grid>
                <!-- LIVE-Indikator oben links -->
                <gemeinsam:LiveIndikator HorizontalAlignment="Left" VerticalAlignment="Top" />

                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <gemeinsam:TeamAnzeige Grid.Column="0"
                                           VerticalAlignment="Center"
                                           LogoPfad="{Binding Team1LogoPfad}"
                                           TeamName="{Binding Team1Name}" />

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="48,0">
                        <!-- Duellstand: Ziffern pulsen bei jeder Änderung -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DuellsiegeTeam1}"
                                       Style="{StaticResource MatchScoreStyle}"
                                       verhalten:WertPulsVerhalten.Wert="{Binding DuellsiegeTeam1}" />
                            <TextBlock Grid.Column="1"
                                       Text=":"
                                       FontSize="80" FontWeight="Light"
                                       VerticalAlignment="Center"
                                       Margin="20,0"
                                       Foreground="{StaticResource PinselTextGedaempft}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DuellsiegeTeam2}"
                                       Style="{StaticResource MatchScoreStyle}"
                                       verhalten:WertPulsVerhalten.Wert="{Binding DuellsiegeTeam2}" />
                        </Grid>
                        <!-- Stechen-Badge -->
                        <Border Style="{StaticResource StechenBadgeStyle}"
                                Visibility="{Binding IstStechen, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,12,0,0">
                            <TextBlock Text="STECHEN"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>

                    <gemeinsam:TeamAnzeige Grid.Column="2"
                                           VerticalAlignment="Center"
                                           LogoPfad="{Binding Team2LogoPfad}"
                                           TeamName="{Binding Team2Name}" />
                </Grid>
            </Grid>
        </Border>

        <!-- ── Duellliste ──────────────────────────────────────────────── -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding Duelle}"
                      Margin="56,28">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource DuellZeileStyle}">
                                <Style.Triggers>
                                    <!-- Noch nicht gestartete Duelle abdimmen -->
                                    <DataTrigger Binding="{Binding IstGeplant}" Value="True">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Duellnummer in Kreis + Stechen-Kennzeichnung -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource KreisNummerStyle}"
                                    HorizontalAlignment="Left">
                                <Grid>
                                    <TextBlock Text="{Binding Duellnummer}"
                                               Foreground="{StaticResource PinselTextGedaempft}"
                                               FontSize="20" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="S"
                                               Foreground="{StaticResource PinselLive}"
                                               FontSize="13" FontWeight="Bold"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Top" Margin="0,2,4,0"
                                               Visibility="{Binding IstStechen, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                            </Border>

                            <!-- Spieler 1 -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Spieler1Name}"
                                       FontSize="28"
                                       Foreground="{StaticResource PinselText}"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0" />

                            <!-- Ergebnis-Pille -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource ErgebnisPilleStyle}"
                                    Margin="16,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding ErgebnisText}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource PinselAkzent}"
                                           HorizontalAlignment="Center" />
                            </Border>

                            <!-- Spieler 2 -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Spieler2Name}"
                                       FontSize="28"
                                       Foreground="{StaticResource PinselText}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ── Versuch-Anzeige ─────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource VerlaufKopf}"
                Padding="56,16"
                BorderBrush="{StaticResource PinselTrennlinie}"
                BorderThickness="0,2,0,0"
                Visibility="{Binding SpielLaeuft, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding AktuellesVersuchText}"
                       Style="{StaticResource AnzeigeTextGedaempftStyle}"
                       FontSize="24"
                       HorizontalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
