<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Anzeige.MatchdayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Datei:   MatchdayView.xaml
        Zweck:   Live-Spielansicht mit Teamnamen, Gesamtstand und Duellliste
        Bereich: Präsentation – Anzeige-Views
    -->
    <Grid Background="{StaticResource AnzeigeHintergrund}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Score-Header -->
            <RowDefinition Height="*" />
            <!-- Duellliste -->
            <RowDefinition Height="Auto" />
            <!-- Versuch-Anzeige -->
        </Grid.RowDefinitions>

        <!-- ── Score-Header ────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource AnzeigeKopfVerlauf}"
                Padding="56,36"
                BorderBrush="{StaticResource AnzeigeTrennlinie}"
                BorderThickness="0,0,0,2">
            <Grid>
                <!-- LIVE-Indikator oben links -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Ellipse Style="{StaticResource LivePunktStyle}" VerticalAlignment="Center" />
                    <TextBlock Text="LIVE"
                               Foreground="#FF6B6B"
                               FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </StackPanel>

                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <Image Source="{Binding Team1LogoPfad, Converter={StaticResource PfadZuBitmap}}"
                               Height="96" Stretch="Uniform"
                               Margin="0,0,0,10"
                               Visibility="{Binding Team1LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                        <TextBlock Text="{Binding Team1Name}"
                                   Style="{StaticResource TeamNameAnzeigeStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="48,0">
                        <!-- Duellstand -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DuellsiegeTeam1}"
                                       Style="{StaticResource ScoreTextStyle}" />
                            <TextBlock Grid.Column="1"
                                       Text=":"
                                       FontSize="80" FontWeight="Light"
                                       VerticalAlignment="Center"
                                       Margin="20,0"
                                       Foreground="{StaticResource AnzeigeTextGedaempft}" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DuellsiegeTeam2}"
                                       Style="{StaticResource ScoreTextStyle}" />
                        </Grid>
                        <!-- Stechen-Badge -->
                        <Border Style="{StaticResource StechenBadgeStyle}"
                                Visibility="{Binding IstStechen, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,12,0,0">
                            <TextBlock Text="STECHEN"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Image Source="{Binding Team2LogoPfad, Converter={StaticResource PfadZuBitmap}}"
                               Height="96" Stretch="Uniform"
                               Margin="0,0,0,10"
                               Visibility="{Binding Team2LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                        <TextBlock Text="{Binding Team2Name}"
                                   Style="{StaticResource TeamNameAnzeigeStyle}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Duellliste ──────────────────────────────────────────────── -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding Duelle}"
                      Margin="56,28">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource DuellZeileStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IstGeplant}" Value="True">
                                        <Setter Property="Opacity" Value="0.4" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Duellnummer in Kreis + Stechen-Kennzeichnung -->
                            <Border Grid.Column="0"
                                    Width="40" Height="40"
                                    CornerRadius="20"
                                    Background="#2A2750"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <TextBlock Text="{Binding Duellnummer}"
                                               Foreground="{StaticResource AnzeigeTextGedaempft}"
                                               FontSize="20" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="S" Foreground="#FF6B6B" FontSize="13"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Top" Margin="0,2,4,0"
                                               Visibility="{Binding IstStechen, Converter={StaticResource BoolToVisibility}}" />
                                </Grid>
                            </Border>

                            <!-- Spieler 1 -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Spieler1Name}"
                                       FontSize="28"
                                       Foreground="{StaticResource AnzeigeText}"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0" />

                            <!-- Ergebnis-Pille -->
                            <Border Grid.Column="2"
                                    Background="#1A1838"
                                    CornerRadius="10"
                                    Padding="20,6"
                                    Margin="16,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding ErgebnisText}"
                                           FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource AnzeigeAkzent}"
                                           HorizontalAlignment="Center" />
                            </Border>

                            <!-- Spieler 2 -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Spieler2Name}"
                                       FontSize="28"
                                       Foreground="{StaticResource AnzeigeText}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ── Versuch-Anzeige ─────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource AnzeigeKopfVerlauf}"
                Padding="56,16"
                BorderBrush="{StaticResource AnzeigeTrennlinie}"
                BorderThickness="0,2,0,0"
                Visibility="{Binding SpielLaeuft, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="{Binding AktuellesVersuchText}"
                       Style="{StaticResource AnzeigeTextGedaempftStyle}"
                       FontSize="24"
                       HorizontalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
