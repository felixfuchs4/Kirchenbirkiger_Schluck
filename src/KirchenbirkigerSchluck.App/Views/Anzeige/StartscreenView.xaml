<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Anzeige.StartscreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Datei:   StartscreenView.xaml
        Zweck:   Vollbild-Startscreen vor Turnierbeginn (Logo, Turniername, Uhrzeit)
        Bereich: Präsentation – Anzeige-Views
    -->
    <Grid Background="{StaticResource VerlaufAnzeigeHintergrund}">

        <!-- Dezenter Lichtschein hinter der Bildmitte -->
        <Ellipse Width="1500" Height="1500"
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Opacity="0.16"
                 Fill="{StaticResource GoldSchein}" />

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="56">

            <!-- Logo – animiertes Highlight: sanftes Einblenden beim Laden,
                 danach dauerhaftes Schweben und Atmen -->
            <Image Source="/Resources/Assets/Logo_Kirchenbirkiger_Schluck.png"
                   MaxHeight="360" MaxWidth="660"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5"
                   Margin="0,0,0,44">
                <Image.RenderTransform>
                    <!-- [0] Einblend-Skalierung (einmalig), [1] Atem-Skalierung (dauerhaft),
                         [2] Schwebe-Versatz (dauerhaft) -->
                    <TransformGroup>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9" />
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                        <TranslateTransform Y="0" />
                    </TransformGroup>
                </Image.RenderTransform>
                <Image.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.6" />
                </Image.Effect>
                <Image.Style>
                    <Style TargetType="Image">
                        <Style.Triggers>
                            <!-- Fallback wenn Logo nicht vorhanden -->
                            <Trigger Property="Source" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- Einblenden: weich aufblenden und leicht heranzoomen -->
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.9">
                                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         From="0.9" To="1" Duration="0:0:0.9">
                                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         From="0.9" To="1" Duration="0:0:0.9">
                                            <DoubleAnimation.EasingFunction><QuarticEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>

                                        <!-- Atmen: dauerhaftes, sehr dezentes Größer-/Kleinerwerden -->
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleX)"
                                                         From="1" To="1.03" Duration="0:0:4"
                                                         BeginTime="0:0:0.9"
                                                         AutoReverse="True" RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(ScaleTransform.ScaleY)"
                                                         From="1" To="1.03" Duration="0:0:4"
                                                         BeginTime="0:0:0.9"
                                                         AutoReverse="True" RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>

                                        <!-- Schweben: langsames Auf- und Abgleiten -->
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[2].(TranslateTransform.Y)"
                                                         From="0" To="-14" Duration="0:0:4.5"
                                                         BeginTime="0:0:0.9"
                                                         AutoReverse="True" RepeatBehavior="Forever">
                                            <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut" /></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Style.Triggers>
                    </Style>
                </Image.Style>
            </Image>

            <!-- Turniername -->
            <TextBlock Text="{Binding TurnierName}"
                       Style="{StaticResource UeberschriftAnzeigeStyle}"
                       FontSize="68"
                       Margin="0,0,0,14"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />

            <!-- Goldene Trennlinie -->
            <Border Height="4" Width="200"
                    Background="{StaticResource VerlaufAkzent}"
                    CornerRadius="2"
                    Margin="0,0,0,48"
                    Effect="{StaticResource GlowGoldSanft}" />

            <!-- Uhrzeit – „atmet" in sehr langsamer Opacity-Schwingung -->
            <TextBlock Text="{Binding AktuelleUhrzeit}"
                       Style="{StaticResource UhrzeitStyle}"
                       FontSize="130">
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="1.0" To="0.82" Duration="0:0:6" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
            </TextBlock>

            <!-- Begrüßungszeile -->
            <TextBlock Text="Herzlich willkommen"
                       Style="{StaticResource AnzeigeTextStyle}"
                       FontSize="34"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,36,0,0"
                       Effect="{StaticResource GlowGoldSanft}" />

        </StackPanel>
    </Grid>
</UserControl>
