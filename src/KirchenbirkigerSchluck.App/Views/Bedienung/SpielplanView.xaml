<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Bedienung.SpielplanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        Datei:   SpielplanView.xaml
        Zweck:   Spielplan-Übersicht mit Start- und Verschiebe-Funktion
        Bereich: Präsentation – Bedienungs-Views
    -->
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Hero: Nächstes Spiel ─────────────────────────────────────── -->
        <materialDesign:Card Grid.Row="0" Padding="0" UniformCornerRadius="8">
            <Border BorderBrush="{StaticResource PinselAkzent}"
                    BorderThickness="0,0,0,2"
                    CornerRadius="8">
                <Grid Margin="24,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Grid.Column="0"
                                             Kind="PlayCircle"
                                             Width="40" Height="40"
                                             Foreground="{StaticResource PinselAkzent}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,18,0" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="NÄCHSTES SPIEL"
                                   Style="{StaticResource BedienHinweisStyle}"
                                   FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding NaechstesSpielText}"
                                   Foreground="{StaticResource PinselText}"
                                   FontSize="22" FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <!-- Primäraktion: nutzt die goldene Primärfarbe des Themes -->
                    <Button Grid.Column="2"
                            Content="▶  Spiel starten"
                            Command="{Binding NaechstesSpielStartenCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="52"
                            Padding="24,0"
                            FontSize="16"
                            FontWeight="Bold" />
                </Grid>
            </Border>
        </materialDesign:Card>

        <!-- ── Spielliste ───────────────────────────────────────────────── -->
        <materialDesign:Card Grid.Row="2" Padding="0" UniformCornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Spaltenheader -->
                <Border Grid.Row="0" Background="{StaticResource PinselFlaecheDunkel}" Padding="20,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" />
                        <TextBlock Grid.Column="1" Text="Begegnung" FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" />
                        <TextBlock Grid.Column="2" Text="Status" FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" />
                        <TextBlock Grid.Column="3" Text="Ergebnis" FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="Runde" FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" />
                    </Grid>
                </Border>

                <!-- Spielzeilen -->
                <ListView Grid.Row="1"
                          ItemsSource="{Binding Spiele}"
                          SelectedItem="{Binding AusgewaehltesSpiel}"
                          Style="{StaticResource MaterialDesignListView}"
                          HorizontalContentAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <!-- Zeilen-Karte: goldene Tönung für nächstes Spiel, Statusfarbe -->
                            <Border Style="{StaticResource SpielZeileStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="56" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="150" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Spielnummer + Akzent-Marker fürs nächste Spiel -->
                                    <Grid Grid.Column="0">
                                        <TextBlock Text="{Binding Nummer}"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PinselTextGedaempft}" />
                                        <Border Width="4" CornerRadius="2"
                                                HorizontalAlignment="Left"
                                                Background="{StaticResource PinselAkzent}"
                                                Margin="-12,2,0,2"
                                                Visibility="{Binding IstNaechstes, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>

                                    <!-- Begegnung: Team 1 vs Team 2 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Image Source="{Binding Team1LogoPfad, Converter={StaticResource PfadZuBitmap}}"
                                               Width="22" Height="22" Stretch="Uniform" Margin="0,0,6,0"
                                               Visibility="{Binding Team1LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                                        <TextBlock Text="{Binding Team1}" FontWeight="Medium" VerticalAlignment="Center" />
                                        <Border Background="{StaticResource PinselFlaecheAktiv}" CornerRadius="4" Padding="6,1" Margin="10,0">
                                            <TextBlock Text="vs" FontSize="11" Foreground="{StaticResource PinselSekundaerHell}" />
                                        </Border>
                                        <Image Source="{Binding Team2LogoPfad, Converter={StaticResource PfadZuBitmap}}"
                                               Width="22" Height="22" Stretch="Uniform" Margin="0,0,6,0"
                                               Visibility="{Binding Team2LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                                        <TextBlock Text="{Binding Team2}" FontWeight="Medium" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!-- Status-Pille -->
                                    <Border Grid.Column="2"
                                            Style="{StaticResource StatusPillStyle}"
                                            Padding="10,3"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Status}"
                                                   Style="{StaticResource StatusPillTextStyle}" />
                                    </Border>

                                    <!-- Ergebnis -->
                                    <TextBlock Grid.Column="3" Text="{Binding Ergebnis}"
                                               FontWeight="Bold" FontSize="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />

                                    <!-- Runde -->
                                    <TextBlock Grid.Column="4" Text="{Binding Runde}"
                                               Foreground="{StaticResource PinselTextGedaempft}"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MaterialDesignCaptionTextBlock}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Aktionsleiste für das ausgewählte Spiel -->
                <Border Grid.Row="2" Padding="16,12"
                        Background="{StaticResource PinselFlaecheDunkel}"
                        BorderBrush="{StaticResource PinselTrennlinie}" BorderThickness="0,1,0,0">
                    <DockPanel>
                        <!-- Hinweis, wenn nichts ausgewählt -->
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Ein Spiel in der Liste auswählen, um Aktionen anzuzeigen."
                                   Foreground="{StaticResource PinselTextGedaempft}" VerticalAlignment="Center"
                                   Visibility="{Binding HatAuswahl, Converter={StaticResource InverseBoolToVisibility}}" />

                        <WrapPanel Visibility="{Binding HatAuswahl, Converter={StaticResource BoolToVisibility}}">
                            <Button Command="{Binding SpielBearbeitenCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PencilOutline" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Bearbeiten" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SpielHierStartenCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PlayCircleOutline" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Spiel starten" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding MatchscreenAnzeigenCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Monitor" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Matchscreen anzeigen" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SpielNeustartenCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="{StaticResource PinselGefahr}" BorderBrush="{StaticResource PinselGefahr}"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Restart" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Neustarten" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding SpielNachHintenVerschiebenCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowDown" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="Nach hinten" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
