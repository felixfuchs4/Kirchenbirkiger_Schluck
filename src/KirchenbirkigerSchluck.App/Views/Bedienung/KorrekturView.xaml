<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Bedienung.KorrekturView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        Datei:   KorrekturView.xaml
        Zweck:   Read-only Anzeige des Änderungsprotokolls
        Bereich: Präsentation – Bedienungs-Views
    -->
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Änderungsprotokoll"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}" />

        <!-- Keine Einträge -->
        <TextBlock Grid.Row="2"
                   Text="Keine Korrekturen bisher erfasst."
                   Foreground="Gray"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignBody1TextBlock}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HatEintraege}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Eintrags-Liste -->
        <materialDesign:Card Grid.Row="2" Padding="0">
            <materialDesign:Card.Style>
                <Style TargetType="materialDesign:Card" BasedOn="{StaticResource {x:Type materialDesign:Card}}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HatEintraege}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </materialDesign:Card.Style>
            <DataGrid ItemsSource="{Binding Eintraege}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="True"
                      Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Zeitpunkt" Binding="{Binding Zeitpunkt}" Width="160" />
                    <DataGridTextColumn Header="Entität" Binding="{Binding Entitaet}" Width="100" />
                    <DataGridTextColumn Header="Feld" Binding="{Binding Feld}" Width="120" />
                    <DataGridTextColumn Header="Alter Wert" Binding="{Binding AlterWert}" Width="*" />
                    <DataGridTextColumn Header="Neuer Wert" Binding="{Binding NeuerWert}" Width="*" />
                    <DataGridTextColumn Header="Begründung" Binding="{Binding Begruendung}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>
