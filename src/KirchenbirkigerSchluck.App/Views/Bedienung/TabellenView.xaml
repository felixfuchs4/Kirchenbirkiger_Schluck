<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Bedienung.TabellenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:gemeinsam="clr-namespace:KirchenbirkigerSchluck.App.Views.Gemeinsam">
    <!--
        Datei:   TabellenView.xaml
        Zweck:   Gruppentabellen-Übersicht im Verwaltungsbildschirm
        Bereich: Präsentation – Bedienungs-Views
    -->
    <Grid Margin="24">
        <!-- Hinweis, wenn keine Tabellen -->
        <gemeinsam:LeererZustand Symbol="TableLarge"
                                 Titel="Noch keine Tabellen"
                                 Hinweis="Tabellen erscheinen, sobald die Gruppen ausgelost und Spiele gewertet sind."
                                 Visibility="{Binding HatTabellen, Converter={StaticResource InverseBoolToVisibility}}" />

        <!-- Gruppentabellen nebeneinander -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HatTabellen, Converter={StaticResource BoolToVisibility}}">
            <ItemsControl ItemsSource="{Binding Gruppen}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><UniformGrid Columns="2" /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="8" Padding="0">
                            <StackPanel>
                                <!-- Gruppenkopf -->
                                <Border Padding="16,12" Background="{StaticResource VerlaufSekundaer}">
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="18" FontWeight="Bold" />
                                </Border>

                                <!-- Spaltenkopf -->
                                <Grid Margin="16,10,16,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="50" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Pl." FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" />
                                    <TextBlock Grid.Column="2" Text="Team" FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" />
                                    <TextBlock Grid.Column="3" Text="Sp." FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="S." FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="5" Text="Duelle" FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="6" Text="Pkt." FontWeight="SemiBold" Foreground="{StaticResource PinselTextGedaempft}" HorizontalAlignment="Center" />
                                </Grid>
                                <Separator Margin="16,0" />

                                <!-- Zeilen -->
                                <ItemsControl ItemsSource="{Binding Zeilen}" Margin="0,4,0,12">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="16,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="50" />
                                                    <ColumnDefinition Width="50" />
                                                    <ColumnDefinition Width="60" />
                                                    <ColumnDefinition Width="60" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Platz, StringFormat='{}{0}.'}" FontWeight="Bold" Foreground="{StaticResource PinselAkzent}" VerticalAlignment="Center" />
                                                <Image Grid.Column="1" Source="{Binding LogoPfad, Converter={StaticResource PfadZuBitmap}}"
                                                       Width="26" Height="26" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"
                                                       Visibility="{Binding LogoPfad, Converter={StaticResource PfadZuVisibility}}" />
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TeamName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <Border Background="{StaticResource PinselStechen}" CornerRadius="6" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                            Visibility="{Binding StechenNoetig, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="Stechen" Foreground="White" FontSize="10" FontWeight="Bold" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Grid.Column="3" Text="{Binding Spiele}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="4" Text="{Binding Siege}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="5" Text="{Binding DuellDifferenz}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PinselTextGedaempft}" />
                                                <TextBlock Grid.Column="6" Text="{Binding Punkte}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
