<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Bedienung.GruppenAuslosungView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        Datei:   GruppenAuslosungView.xaml
        Zweck:   Animierte Gruppenauslosung (DFB-Pokal-Stil) und Einteilungsübersicht
        Bereich: Präsentation – Bedienungs-Views
    -->
    <UserControl.Resources>
        <!-- Team-Kugel mit Einpop-Animation beim Erscheinen -->
        <Style x:Key="TeamKugelStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="BorderBrush" Value="#D1C4E9" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#5E35B1" BlurRadius="10" ShadowDepth="0" Opacity="0.18" />
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.45" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                             From="0.2" To="1" Duration="0:0:0.45">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.6" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                             From="0.2" To="1" Duration="0:0:0.45">
                                <DoubleAnimation.EasingFunction>
                                    <BackEase EasingMode="EaseOut" Amplitude="0.6" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Konfiguration / Steuerung ────────────────────────────────── -->
        <materialDesign:Card Grid.Row="0" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Gruppenauslosung"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" />
                    <TextBlock Text="{Binding StatusText}"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               MaxWidth="520"
                               Margin="0,2,0,0" />
                </StackPanel>

                <ComboBox Grid.Column="1"
                          materialDesign:HintAssist.Hint="Anzahl Gruppen"
                          ItemsSource="{Binding MoeglicheGruppenAnzahlen}"
                          SelectedItem="{Binding AnzahlGruppen}"
                          IsEnabled="{Binding IstInVorbereitung}"
                          Width="140"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="0,0,16,0"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding AuslosungStartenCommand}"
                            Height="48" Padding="22,0" FontWeight="SemiBold">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IstAusgelost}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IstInVorbereitung}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Shuffle" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Auslosung starten" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding AuslosungStartenCommand}"
                            Height="48" Padding="22,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IstAusgelost}" Value="True" />
                                            <Condition Binding="{Binding IstInVorbereitung}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Restart" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Neu auslosen" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- ── Hinweis: Auslosung läuft am Beamer ───────────────────────── -->
        <Border Grid.Row="1"
                Margin="0,16,0,0"
                CornerRadius="12"
                Padding="24,20"
                Visibility="{Binding ZiehungLaeuft, Converter={StaticResource BoolToVisibility}}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#311B92" Offset="0" />
                    <GradientStop Color="#5E35B1" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <materialDesign:PackIcon Kind="Monitor" Width="32" Height="32"
                                         Foreground="#FFC84B"
                                         VerticalAlignment="Center" Margin="0,0,16,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Die Auslosung läuft am Beamer"
                               Foreground="White"
                               FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="Bitte die Animation auf der Anzeige abwarten – die Gruppen werden danach automatisch eingetragen."
                               Foreground="#D9CCF2"
                               FontSize="13"
                               TextWrapping="Wrap"
                               MaxWidth="520" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Gruppen-Übersicht ────────────────────────────────────────── -->
        <Grid Grid.Row="2" Margin="0,16,0,0">

            <!-- Platzhalter, wenn noch nichts ausgelost -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Gruppen.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="ShuffleVariant"
                                         Width="72" Height="72"
                                         Foreground="#CCCCCC"
                                         HorizontalAlignment="Center" />
                <TextBlock Text="Noch keine Auslosung"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0" />
                <TextBlock Text="Anzahl Gruppen wählen und die Auslosung starten."
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />
            </StackPanel>

            <!-- Gruppen-Spalten -->
            <ItemsControl ItemsSource="{Binding Gruppen}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="6,0" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!-- Gruppen-Kopf -->
                                <Border Grid.Row="0" Padding="16,12" CornerRadius="4,4,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#5E35B1" Offset="0" />
                                            <GradientStop Color="#7E57C2" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   FontSize="18" FontWeight="Bold"
                                                   VerticalAlignment="Center" />
                                        <Border Background="#33FFFFFF" CornerRadius="10"
                                                Padding="8,2" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Teams.Count}"
                                                       Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Team-Kugeln -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14,12">
                                    <ItemsControl ItemsSource="{Binding Teams}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource TeamKugelStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="10" Height="10" Fill="#5E35B1"
                                                                 VerticalAlignment="Center" Margin="0,0,12,0" />
                                                        <TextBlock Text="{Binding}"
                                                                   FontWeight="SemiBold" FontSize="15"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
