<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Bedienung.SpielsteuerungView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        Datei:   SpielsteuerungView.xaml
        Zweck:   Live-Spielsteuerung: Spieler auswählen, Versuche erfassen, Spiel abschließen
        Bereich: Präsentation – Bedienungs-Views
    -->
    <Grid Margin="24">
        <!-- Kein aktives Spiel -->
        <TextBlock Text="Kein laufendes Spiel.&#x0a;Starte ein Spiel im Spielplan-Tab."
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Foreground="Gray">
            <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignHeadline5TextBlock}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SpielLaeuft}" Value="False">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Aktives Spiel -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SpielLaeuft}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Score-Header -->
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <!-- Duell-Auswahl -->
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <!-- Versuch-Buttons -->
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
                <!-- Duell-Übersicht -->
                <RowDefinition Height="Auto" />
                <!-- Abschluss -->
            </Grid.RowDefinitions>

            <!-- ── Score-Header ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Row="0" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Team1Name}"
                               Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="24,0">
                        <TextBlock FontSize="36" FontWeight="Bold" HorizontalAlignment="Center">
                            <Run Text="{Binding DuellsiegeTeam1}" />
                            <Run Text=" : " Foreground="Gray" />
                            <Run Text="{Binding DuellsiegeTeam2}" />
                        </TextBlock>
                        <materialDesign:Chip Content="STECHEN"
                                            Background="Red" Foreground="White"
                                            IsEnabled="False"
                                            HorizontalAlignment="Center"
                                            Visibility="{Binding IstStechen, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding Team2Name}"
                               Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center" />
                </Grid>
            </materialDesign:Card>

            <!-- ── Duell-Auswahl ──────────────────────────────────────── -->
            <materialDesign:Card Grid.Row="2" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              materialDesign:HintAssist.Hint="{Binding Team1Name}"
                              ItemsSource="{Binding Team1Spieler}"
                              SelectedItem="{Binding GewaehlterSpieler1}"
                              DisplayMemberPath="Name"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                    <TextBlock Grid.Column="1" Text="vs." VerticalAlignment="Center"
                               Margin="12,0" Foreground="Gray" />
                    <ComboBox Grid.Column="2"
                              materialDesign:HintAssist.Hint="{Binding Team2Name}"
                              ItemsSource="{Binding Team2Spieler}"
                              SelectedItem="{Binding GewaehlterSpieler2}"
                              DisplayMemberPath="Name"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <Button Content="Duell starten"
                                Command="{Binding DuellStartenCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="0,0,8,0" />
                        <Button Content="Stechen starten"
                                Command="{Binding StechenStartenCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Visibility="{Binding IstStechen, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- ── Versuch-Buttons (2×2) ──────────────────────────────── -->
            <materialDesign:Card Grid.Row="4" Padding="16">
                <StackPanel>
                    <TextBlock Text="{Binding AktuellesVersuchText}"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0"
                                Style="{StaticResource VersuchButtonStyle}"
                                Command="{Binding Team1TrifftCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Team1Name}" VerticalAlignment="Center" />
                                <TextBlock Text=" trifft" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="2"
                                Style="{StaticResource VersuchButtonStyle}"
                                Command="{Binding Team2TrifftCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Team2Name}" VerticalAlignment="Center" />
                                <TextBlock Text=" trifft" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="2" Grid.Column="0"
                                Content="Beide treffen"
                                Style="{StaticResource VersuchButtonStyle}"
                                Command="{Binding BeidetreffenCommand}" />
                        <Button Grid.Row="2" Grid.Column="2"
                                Content="Keiner trifft"
                                Style="{StaticResource VersuchButtonStyle}"
                                Command="{Binding BeideNichtTreffenCommand}" />
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Duell-Übersicht (editierbar: Spieler + Trefferzahl) ───── -->
            <materialDesign:Card Grid.Row="6" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Duelle – Spieler und Trefferzahl direkt änderbar (Korrektur)"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="Gray" Margin="4,0,0,8" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BearbeitbareDuelle}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="34" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="64" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Duellnummer}"
                                                   Foreground="Gray" VerticalAlignment="Center" />

                                        <!-- Geplanter Slot: nur Vorschau -->
                                        <TextBlock Grid.Column="1" Text="{Binding Spieler1Vorschau}"
                                                   VerticalAlignment="Center" Opacity="0.45"
                                                   Visibility="{Binding IstGeplant, Converter={StaticResource BoolToVisibility}}" />
                                        <TextBlock Grid.Column="5" Text="{Binding Spieler2Vorschau}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" Opacity="0.45"
                                                   Visibility="{Binding IstGeplant, Converter={StaticResource BoolToVisibility}}" />
                                        <TextBlock Grid.Column="3" Text="–" Foreground="Gray"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.45"
                                                   Visibility="{Binding IstGeplant, Converter={StaticResource BoolToVisibility}}" />

                                        <!-- Gespieltes Duell: editierbar -->
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding Team1Spieler}"
                                                  SelectedItem="{Binding GewaehlterSpieler1}"
                                                  DisplayMemberPath="Name"
                                                  VerticalAlignment="Center" Margin="0,0,8,0"
                                                  Visibility="{Binding IstGeplant, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <!-- Treffer-Spinner Spieler 1 -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IstGeplant, Converter={StaticResource InverseBoolToVisibility}}">
                                            <Button Command="{Binding Treffer1SenkenCommand}"
                                                    Style="{StaticResource MaterialDesignIconButton}" Width="26" Height="26" Padding="0" ToolTip="Treffer −">
                                                <materialDesign:PackIcon Kind="Minus" Width="16" Height="16" />
                                            </Button>
                                            <TextBlock Text="{Binding Treffer1}" FontWeight="Bold" FontSize="16"
                                                       Width="22" TextAlignment="Center" VerticalAlignment="Center" />
                                            <Button Command="{Binding Treffer1ErhoehenCommand}"
                                                    Style="{StaticResource MaterialDesignIconButton}" Width="26" Height="26" Padding="0" ToolTip="Treffer +">
                                                <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                        <TextBlock Grid.Column="3" Text=":" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding IstGeplant, Converter={StaticResource InverseBoolToVisibility}}" />
                                        <!-- Treffer-Spinner Spieler 2 -->
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding IstGeplant, Converter={StaticResource InverseBoolToVisibility}}">
                                            <Button Command="{Binding Treffer2SenkenCommand}"
                                                    Style="{StaticResource MaterialDesignIconButton}" Width="26" Height="26" Padding="0" ToolTip="Treffer −">
                                                <materialDesign:PackIcon Kind="Minus" Width="16" Height="16" />
                                            </Button>
                                            <TextBlock Text="{Binding Treffer2}" FontWeight="Bold" FontSize="16"
                                                       Width="22" TextAlignment="Center" VerticalAlignment="Center" />
                                            <Button Command="{Binding Treffer2ErhoehenCommand}"
                                                    Style="{StaticResource MaterialDesignIconButton}" Width="26" Height="26" Padding="0" ToolTip="Treffer +">
                                                <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                        <ComboBox Grid.Column="5"
                                                  ItemsSource="{Binding Team2Spieler}"
                                                  SelectedItem="{Binding GewaehlterSpieler2}"
                                                  DisplayMemberPath="Name"
                                                  VerticalAlignment="Center" Margin="8,0,0,0"
                                                  Visibility="{Binding IstGeplant, Converter={StaticResource InverseBoolToVisibility}}" />

                                        <!-- Badge -->
                                        <TextBlock Grid.Column="6" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="10" Foreground="Gray">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IstGeplant}" Value="True">
                                                            <Setter Property="Text" Value="geplant" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IstStechen}" Value="True">
                                                            <Setter Property="Text" Value="Stechen" />
                                                            <Setter Property="Foreground" Value="Red" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </materialDesign:Card>

            <!-- ── Spiel abschließen ───────────────────────────────────── -->
            <Border Grid.Row="7" Padding="0,12,0,0">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <!-- Hinweis warum noch nicht abgeschlossen werden kann -->
                    <TextBlock Text="Alle 5 Duelle abschließen, dann Spiel beenden."
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding KannSpielAbschliessen}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Content="Spiel abschließen"
                            Command="{Binding SpielAbschliessenCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            IsEnabled="{Binding KannSpielAbschliessen}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
