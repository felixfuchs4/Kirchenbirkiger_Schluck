<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Bedienung.TurnierVerwaltungView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        Datei:   TurnierVerwaltungView.xaml
        Zweck:   Turnier anlegen, laden, speichern und Teams verwalten
        Bereich: Präsentation – Bedienungs-Views
    -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Linke Spalte: Neues Turnier + Laden/Speichern ─────── -->

            <!-- Neues Turnier -->
            <materialDesign:Card Grid.Column="0" Grid.Row="0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Neues Turnier anlegen"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="0,0,0,16" />

                    <TextBox materialDesign:HintAssist.Hint="Anlass (Pflichtfeld)"
                             Text="{Binding NeuerAnlass, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                    <DatePicker materialDesign:HintAssist.Hint="Turnierdatum (Pflichtfeld)"
                                SelectedDate="{Binding NeuesTournierDatum}"
                                Margin="0,0,0,12"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                    <ComboBox materialDesign:HintAssist.Hint="Wertungssystem"
                              ItemsSource="{Binding AlleWertungssysteme}"
                              SelectedItem="{Binding GewaehltesBewertungssystem}"
                              Margin="0,0,0,12"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                    <ComboBox materialDesign:HintAssist.Hint="Finalrunden-Modus"
                              ItemsSource="{Binding AlleFinalrundenModi}"
                              SelectedItem="{Binding GewaehlterFinalrundenModus}"
                              Margin="0,0,0,4"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                    <TextBlock Text="Die kurze Finalrunde gilt nur für genau zwei Gruppen. Bei einer, drei oder vier Gruppen wird stets ein K.-o.-Baum erzeugt."
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource PinselTextGedaempft}"
                               TextWrapping="Wrap" Margin="0,0,0,12" />

                    <ComboBox materialDesign:HintAssist.Hint="Torschützenkönig-Wertung"
                              ItemsSource="{Binding AlleTorschuetzenWertungen}"
                              SelectedItem="{Binding GewaehlteTorschuetzenWertung}"
                              Margin="0,0,0,12"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                    <TextBlock Text="Gruppen werden im Tab „Gruppen“ ausgelost."
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource PinselTextGedaempft}"
                               Margin="0,0,0,12" />

                    <Button Content="Turnier erstellen"
                            Command="{Binding TurnierErstellenCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </materialDesign:Card>

            <!-- Speicherstände: benannt speichern, laden, löschen -->
            <materialDesign:Card Grid.Column="0" Grid.Row="2" Padding="16">
                <StackPanel>
                    <TextBlock Text="Speicherstände"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Ein Speicherstand sichert den kompletten Turnierstand (Teams, Spieler, Gruppen, Spielplan, Ergebnisse)."
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource PinselTextGedaempft}"
                               TextWrapping="Wrap" Margin="0,0,0,12" />

                    <!-- Schnellspeichern des Arbeitsstands -->
                    <Button Content="Arbeitsstand jetzt speichern"
                            Command="{Binding TurnierSpeichernCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,16" />

                    <!-- Speichern unter (Titel + optionale Beschreibung) -->
                    <TextBox materialDesign:HintAssist.Hint="Titel des Speicherstands"
                             Text="{Binding SpeicherstandTitel, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    <TextBox materialDesign:HintAssist.Hint="Kurzbeschreibung (optional)"
                             Text="{Binding SpeicherstandBeschreibung, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    <Button Content="Speichern unter"
                            Command="{Binding SpeichernUnterCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Left" Margin="0,0,0,16" />

                    <!-- Liste vorhandener Speicherstände (benannt + automatische Backups) -->
                    <DockPanel Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right"
                                Command="{Binding SpeicherstaendeAktualisierenCommand}"
                                Style="{StaticResource MaterialDesignIconButton}"
                                Width="28" Height="28" Padding="0" ToolTip="Liste aktualisieren">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" />
                        </Button>
                        <TextBlock Text="Vorhandene Speicherstände"
                                   Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <ListBox ItemsSource="{Binding Speicherstaende}"
                             SelectedItem="{Binding AusgewaehlterSpeicherstand}"
                             MaxHeight="240"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Margin="0,0,0,8">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,2">
                                    <TextBlock Text="{Binding Titel}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Beschreibung}"
                                               Foreground="{StaticResource PinselTextGedaempft}"
                                               TextWrapping="Wrap" FontSize="12" />
                                    <TextBlock FontSize="11" Foreground="{StaticResource PinselTextGedaempft}">
                                        <Run Text="{Binding Typ, Mode=OneWay}" />
                                        <Run Text=" · " />
                                        <Run Text="{Binding GespeichertAm, Mode=OneWay, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" />
                                        <Run Text=" · " />
                                        <Run Text="{Binding Status, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Laden"
                                Command="{Binding SpeicherstandLadenCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Margin="0,0,8,0" />
                        <Button Content="Löschen"
                                Command="{Binding SpeicherstandLoeschenCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Rechte Spalte: Aktuelles Turnier + Teams ───────────── -->

            <!-- Aktuelles Turnier -->
            <materialDesign:Card Grid.Column="2" Grid.Row="0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Aktuelles Turnier"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="0,0,0,16" />

                    <TextBlock Text="{Binding TurnierInfo}"
                               Style="{StaticResource MaterialDesignBody1TextBlock}"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <materialDesign:Chip Content="{Binding TurnierStatusText}"
                                            IsEnabled="False"
                                            Margin="0,0,8,0" />
                        <Button Content="Status weiterschalten"
                                Command="{Binding StatusWechselnCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Padding="8,4" />
                        <Button Command="{Binding TurnierZuruecksetzenCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{StaticResource PinselGefahr}"
                                Padding="8,4"
                                ToolTip="Setzt das Turnier in den Anfangszustand zurück. Teams und Spieler bleiben erhalten.">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Restore" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="Zurücksetzen" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding NaechsterSchrittHinweis}"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource PinselAkzent}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                    <Button Command="{Binding ZurGruppenauslosungCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Left"
                            Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ShuffleVariant" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Zur Gruppenauslosung" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding FinalrundeNeuErzeugenCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Tournament" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Finalrunde neu erzeugen" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </materialDesign:Card>

            <!-- Teams -->
            <materialDesign:Card Grid.Column="2" Grid.Row="2" Padding="16">
                <StackPanel>
                    <TextBlock Text="Teams"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="0,0,0,4" />

                    <!-- Hinweis: Teams können nur in der Vorbereitungsphase hinzugefügt werden -->
                    <TextBlock Text="Teams können nach dem Start nicht mehr geändert werden."
                               Foreground="{StaticResource PinselTextGedaempft}"
                               Margin="0,0,0,12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MaterialDesignCaptionTextBlock}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TurnierStatusText}" Value="Gruppenphase läuft">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TurnierStatusText}" Value="Finalrunde">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding TurnierStatusText}" Value="Abgeschlossen">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Team hinzufügen -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 materialDesign:HintAssist.Hint="Teamname"
                                 Text="{Binding NeuerTeamName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        <TextBox Grid.Column="2"
                                 materialDesign:HintAssist.Hint="Kürzel (optional)"
                                 Text="{Binding NeuerKurzname, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                        <Button Grid.Column="4"
                                Content="+"
                                Command="{Binding TeamHinzufuegenCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Width="40" Padding="0" />
                    </Grid>

                    <!-- Team-Liste (Überblick) -->
                    <ListBox ItemsSource="{Binding Teams}"
                             SelectedItem="{Binding AusgewaehlterTeam}"
                             DisplayMemberPath="AnzeigeName"
                             MaxHeight="220"
                             Style="{StaticResource MaterialDesignListBox}" />

                    <!-- Verweis auf die dedizierte Teamverwaltung -->
                    <Border Style="{StaticResource HinweisFlaecheStyle}"
                            Margin="0,12,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="InformationOutline"
                                                     Width="20" Height="20"
                                                     VerticalAlignment="Center"
                                                     Foreground="{StaticResource PinselSekundaerHell}"
                                                     Margin="0,0,10,0" />
                            <TextBlock TextWrapping="Wrap" VerticalAlignment="Center"
                                       Foreground="{StaticResource PinselSekundaerHell}">
                                <Run Text="Spieler und Teamdetails im Tab " />
                                <Run Text="Teamverwaltung" FontWeight="Bold" />
                                <Run Text=" pflegen." />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
