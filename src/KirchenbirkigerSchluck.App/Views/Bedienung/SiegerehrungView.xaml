<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Bedienung.SiegerehrungView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <!--
        Datei:   SiegerehrungView.xaml
        Zweck:   Steuerung der schrittweisen Siegerehrung
        Bereich: Präsentation – Bedienungs-Views
    -->
    <Grid Margin="24">
        <materialDesign:Card Padding="24" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Siegerehrung"
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           Margin="0,0,0,8" />
                <TextBlock Text="Steuert die Ehrung auf dem Anzeigefenster. Reihenfolge: zuerst die fünf treffsichersten Spieler (Platz 5 → 1), danach die Teams (vom schlechtesten zum Sieger)."
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Foreground="{StaticResource PinselTextGedaempft}" TextWrapping="Wrap" Margin="0,0,0,20" />

                <ComboBox materialDesign:HintAssist.Hint="Torschützenkönig-Wertung"
                          ItemsSource="{Binding AlleWertungen}"
                          SelectedItem="{Binding GewaehlteWertung}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Width="280" HorizontalAlignment="Left" Margin="0,0,0,20" />

                <!-- Stechen um Platz 1 bei Gleichstand in der Torschützen-Rangliste -->
                <materialDesign:Card Padding="20" Margin="0,0,0,20"
                                      Background="{StaticResource PinselFlaecheDunkel}"
                                      Visibility="{Binding StechenErforderlich, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Stechen um Platz 1 erforderlich"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   Foreground="{StaticResource PinselAkzent}" Margin="0,0,0,4" />
                        <TextBlock Text="Mehrere Spieler sind bei der Trefferauswertung exakt gleichauf. Stechen live durchführen und den Sieger hier bestätigen."
                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Foreground="{StaticResource PinselTextGedaempft}" TextWrapping="Wrap" Margin="0,0,0,12" />

                        <ComboBox materialDesign:HintAssist.Hint="Sieger des Stechens"
                                  ItemsSource="{Binding StechenKandidaten}"
                                  SelectedItem="{Binding StechenAuswahl}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Width="280" HorizontalAlignment="Left" Margin="0,0,0,12" />

                        <Button Command="{Binding StechenSiegerBestaetigenCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                HorizontalAlignment="Left" Padding="20,0" Height="44" Margin="0,0,0,12">
                            <TextBlock Text="Sieger bestätigen" />
                        </Button>

                        <TextBlock Text="{Binding StechenAuswahl.Name, StringFormat='Bestätigt: {0} ist Platz 1'}"
                                   Foreground="{StaticResource PinselAkzent}" FontWeight="SemiBold"
                                   Visibility="{Binding StechenEntschieden, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </materialDesign:Card>

                <Button Command="{Binding StartenCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        HorizontalAlignment="Left" Height="52" Padding="24,0" FontWeight="SemiBold"
                        Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TrophyVariant" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="Siegerehrung starten" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Aktueller Schritt -->
                <materialDesign:Card Padding="20" Background="{StaticResource PinselFlaecheDunkel}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Aktuell angezeigt:"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{StaticResource PinselTextGedaempft}" />
                        <TextBlock Text="{Binding GewinnerVm.VorschauText}"
                                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                                   TextWrapping="Wrap" Margin="0,4,0,0" />
                        <TextBlock Text="{Binding GewinnerVm.Fortschritt}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{StaticResource PinselTextGedaempft}" Margin="0,6,0,0" />
                    </StackPanel>
                </materialDesign:Card>

                <StackPanel Orientation="Horizontal">
                    <Button Command="{Binding ZurueckCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="56" Padding="28,0" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24" VerticalAlignment="Center" />
                            <TextBlock Text="Zurück" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding WeiterCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="56" Padding="36,0" FontSize="16" FontWeight="Bold" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Weiter" VerticalAlignment="Center" />
                            <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding GewinnerScreenZeigenCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Height="56" Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Monitor" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Gewinner-Screen zeigen" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
