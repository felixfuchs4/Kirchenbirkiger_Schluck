<UserControl x:Class="KirchenbirkigerSchluck.App.Views.Bedienung.EinstellungenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!--
        Datei:   EinstellungenView.xaml
        Zweck:   Backup-Verwaltung, Anzeige-Steuerung und Rotationsintervall
        Bereich: Präsentation – Bedienungs-Views
    -->
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Linke Spalte: Backup ───────────────────────────────── -->
            <materialDesign:Card Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Backup"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" />

                    <Button Grid.Row="2"
                            Content="Backup jetzt erstellen"
                            Command="{Binding BackupErstellenCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Left" />

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Vorhandene Backups:"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Margin="0,0,0,8" />
                        <ListBox ItemsSource="{Binding VerfuegbareBackups}"
                                 SelectedItem="{Binding AusgewaehltesBackup}"
                                 MaxHeight="300"
                                 Style="{StaticResource MaterialDesignListBox}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Anzeigename}"
                                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Grid.Row="6">
                        <TextBlock Text="{Binding AusgewaehltesBackupName}"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Foreground="{StaticResource PinselTextGedaempft}"
                                   Margin="0,0,0,8"
                                   TextWrapping="Wrap" />
                        <Button Content="Ausgewähltes Backup wiederherstellen"
                                Command="{Binding BackupWiederherstellenCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>

            <!-- ── Rechte Spalte oben: Anzeige-Steuerung ─────────────── -->
            <materialDesign:Card Grid.Column="2" Grid.Row="0" Padding="16">
                <StackPanel>
                    <TextBlock Text="Anzeigeoberfläche"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="0,0,0,16" />
                    <TextBlock Text="Manuell umschalten auf:"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Margin="0,0,0,8" />
                    <WrapPanel>
                        <Button Content="Startscreen"
                                Command="{Binding ZeigeStartscreenCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,8" />
                        <Button Content="Infoscreen"
                                Command="{Binding ZeigeInfoscreenCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,8" />
                        <Button Content="Matchday"
                                Command="{Binding ZeigeMatchdayCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,8" />
                        <Button Content="Gewinner"
                                Command="{Binding ZeigeGewinnerCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Margin="0,0,8,8" />
                    </WrapPanel>

                    <Separator Margin="0,12,0,8" />
                    <TextBlock Text="Infoscreen-Folien anzeigen:"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Margin="0,0,0,8" />
                    <CheckBox Content="Nächste Partie"
                              IsChecked="{Binding InfoscreenEinstellungen.ZeigeNaechste}" Margin="0,2" />
                    <CheckBox Content="Letzte Partie"
                              IsChecked="{Binding InfoscreenEinstellungen.ZeigeLetzte}" Margin="0,2" />
                    <CheckBox Content="Gruppentabellen (nur Gruppenphase)"
                              IsChecked="{Binding InfoscreenEinstellungen.ZeigeTabellen}" Margin="0,2" />
                    <CheckBox Content="Spielplan (nur Gruppenphase)"
                              IsChecked="{Binding InfoscreenEinstellungen.ZeigeSpielplan}" Margin="0,2" />
                    <CheckBox Content="Finalrunden-Baum"
                              IsChecked="{Binding InfoscreenEinstellungen.ZeigeBracket}" Margin="0,2" />
                    <TextBlock Text="In der Finalphase werden Tabellen und Spielplan automatisch ausgeblendet."
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource PinselTextGedaempft}" TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </materialDesign:Card>

            <!-- ── Rechte Spalte unten: Rotationsintervall ───────────── -->
            <materialDesign:Card Grid.Column="2" Grid.Row="2" Padding="16">
                <StackPanel>
                    <TextBlock Text="Infoscreen-Rotation"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               Margin="0,0,0,16" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Minimum="3" Maximum="30"
                                Value="{Binding RotationsIntervallSekunden}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Style="{StaticResource MaterialDesignSlider}"
                                VerticalAlignment="Center" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding RotationsIntervallSekunden}"
                                 materialDesign:HintAssist.Hint="Sekunden"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                    </Grid>
                    <TextBlock Text="Sekunden pro Folie"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Foreground="{StaticResource PinselTextGedaempft}" />
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
