<Window x:Class="KirchenbirkigerSchluck.App.Windows.BedienWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="Kirchenbirkiger Schluck – Turnierleitung"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="1024"
        WindowStartupLocation="CenterScreen">
    <!-- Platzhalter: Inhalte folgen mit der UI-Implementierung -->
    <Grid>
        <TextBlock Text="Kirchenbirkiger Schluck – Bedienoberfläche"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Style="{StaticResource MaterialDesignHeadline4TextBlock}" />
    </Grid>
</Window>
