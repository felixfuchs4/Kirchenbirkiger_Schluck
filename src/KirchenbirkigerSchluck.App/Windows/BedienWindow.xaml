<Window x:Class="KirchenbirkigerSchluck.App.Windows.BedienWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vmBedienung="clr-namespace:KirchenbirkigerSchluck.App.ViewModels.Bedienung"
        xmlns:viewsBedienung="clr-namespace:KirchenbirkigerSchluck.App.Views.Bedienung"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        TextElement.FontSize="14"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="Kirchenbirkiger Schluck – Turnierleitung"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="1024"
        WindowStartupLocation="CenterScreen">
    <!--
        Datei:   BedienWindow.xaml
        Zweck:   Hauptfenster der Turnierleitung mit Tab-Navigation
        Bereich: Präsentation – Bedienoberfläche
    -->
    <Window.Resources>
        <!-- DataTemplates: Tab-ViewModel-Typ → UserControl -->
        <DataTemplate DataType="{x:Type vmBedienung:TurnierVerwaltungViewModel}">
            <viewsBedienung:TurnierVerwaltungView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmBedienung:TeamverwaltungViewModel}">
            <viewsBedienung:TeamverwaltungView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmBedienung:GruppenAuslosungViewModel}">
            <viewsBedienung:GruppenAuslosungView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmBedienung:SpielplanViewModel}">
            <viewsBedienung:SpielplanView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmBedienung:TabellenViewModel}">
            <viewsBedienung:TabellenView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmBedienung:SpielsteuerungViewModel}">
            <viewsBedienung:SpielsteuerungView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmBedienung:KorrekturViewModel}">
            <viewsBedienung:KorrekturView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmBedienung:SiegerehrungViewModel}">
            <viewsBedienung:SiegerehrungView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmBedienung:EinstellungenViewModel}">
            <viewsBedienung:EinstellungenView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── Linke Navigationsleiste ────────────────────────────────── -->
        <Border Grid.Column="0" Background="{StaticResource PinselNavigation}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!-- Marken-Header -->
                    <RowDefinition Height="*" />
                    <!-- Navigationspunkte -->
                </Grid.RowDefinitions>

                <!-- Marken-Header -->
                <Border Grid.Row="0" Padding="24,28,24,24">
                    <StackPanel>
                        <Border Width="44" Height="4"
                                Background="{StaticResource PinselAkzent}"
                                CornerRadius="2"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16" />
                        <TextBlock Text="Kirchenbirkiger"
                                   Foreground="{StaticResource PinselText}"
                                   FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="Schluck"
                                   Foreground="{StaticResource PinselAkzent}"
                                   FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="TURNIERLEITUNG"
                                   Foreground="{StaticResource PinselTextGedaempft}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <!-- Navigationspunkte -->
                <TabControl Grid.Row="1"
                            TabStripPlacement="Left"
                            SelectedIndex="{Binding AusgewaehlterTabIndex}"
                            BorderThickness="0"
                            Background="Transparent">
                    <TabControl.Resources>
                        <Style TargetType="TabPanel">
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </TabControl.Resources>
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Height" Value="56" />
                            <Setter Property="Width" Value="220" />
                            <Setter Property="Foreground" Value="{StaticResource PinselTextGedaempft}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <!-- Flächen als Ebenen: Hover und Selektion blenden
                                         weich über Opacity ein (kein Layout-Sprung) -->
                                    <ControlTemplate TargetType="TabItem">
                                        <Grid>
                                            <Border x:Name="HoverFlaeche"
                                                    Background="{StaticResource PinselFlaecheHover}"
                                                    Opacity="0" />
                                            <Border x:Name="AktivFlaeche"
                                                    Background="{StaticResource PinselFlaecheAktiv}"
                                                    Opacity="0" />
                                            <!-- Goldener Selektions-Indikator am linken Rand -->
                                            <Border x:Name="Indikator"
                                                    Width="4" Margin="0,12"
                                                    HorizontalAlignment="Left"
                                                    CornerRadius="0,2,2,0"
                                                    Background="{StaticResource PinselAkzent}"
                                                    Opacity="0" />
                                            <ContentPresenter ContentSource="Header"
                                                              VerticalAlignment="Center"
                                                              Margin="24,0,20,0" />
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverFlaeche"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="1" Duration="{StaticResource DauerFlink}"
                                                                             EasingFunction="{StaticResource EasingStandard}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="HoverFlaeche"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="0" Duration="{StaticResource DauerFlink}"
                                                                             EasingFunction="{StaticResource EasingStandard}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource PinselText}" />
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="AktivFlaeche"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="1" Duration="{StaticResource DauerFlink}"
                                                                             EasingFunction="{StaticResource EasingStandard}" />
                                                            <DoubleAnimation Storyboard.TargetName="Indikator"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="1" Duration="{StaticResource DauerFlink}"
                                                                             EasingFunction="{StaticResource EasingStandard}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="AktivFlaeche"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="0" Duration="{StaticResource DauerFlink}"
                                                                             EasingFunction="{StaticResource EasingStandard}" />
                                                            <DoubleAnimation Storyboard.TargetName="Indikator"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="0" Duration="{StaticResource DauerFlink}"
                                                                             EasingFunction="{StaticResource EasingStandard}" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.ItemContainerStyle>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TrophyOutline" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="Turnier" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroup" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="Teamverwaltung" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ShuffleVariant" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="Gruppen" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FormatListBulleted" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="Spielplan" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TableLarge" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="Tabellen" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlayCircleOutline" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="Spiel" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PencilOutline" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="Korrekturen" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TrophyVariant" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="Siegerehrung" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cog" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,14,0" />
                                <TextBlock Text="Einstellungen" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </TabItem.Header>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- ── Inhaltsbereich (rechts): DataTemplate-Dispatch ─────────── -->
        <Border Grid.Column="1" Background="{DynamicResource MaterialDesign.Brush.Background}">
            <ContentControl Content="{Binding AktivesTabViewModel}" />
        </Border>
    </Grid>
</Window>
