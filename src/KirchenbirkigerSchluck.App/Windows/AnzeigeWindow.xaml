<Window x:Class="KirchenbirkigerSchluck.App.Windows.AnzeigeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontSize="16"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="Kirchenbirkiger Schluck – Anzeige"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize">
    <!-- Vollbild-Anzeigeoberfläche für Beamer/Zuschauer -->
    <!-- Platzhalter: Inhalte folgen mit der UI-Implementierung -->
    <Grid>
        <TextBlock Text="Kirchenbirkiger Schluck – Anzeigeoberfläche"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Style="{StaticResource MaterialDesignHeadline3TextBlock}" />
    </Grid>
</Window>
