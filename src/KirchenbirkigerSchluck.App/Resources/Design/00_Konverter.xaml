<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:KirchenbirkigerSchluck.App.Converters">

    <!-- ================================================================
         Datei:   00_Konverter.xaml
         Zweck:   Zentrale Registrierung aller Wert-Konverter
         Bereich: Präsentation – Designsystem
    ================================================================ -->

    <!-- Standard-Konverter: bool → Visibility -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <!-- Eigene Konverter: Logo-Pfade und invertierte Sichtbarkeit -->
    <conv:PfadZuBitmapConverter x:Key="PfadZuBitmap" />
    <conv:PfadZuVisibilityConverter x:Key="PfadZuVisibility" />
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

</ResourceDictionary>
