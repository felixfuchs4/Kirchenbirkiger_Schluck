<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ================================================================
         Datei:   05_Anzeige.xaml
         Zweck:   Komponenten-Styles der Anzeigeoberfläche (Beamer):
                  Karten, Listenzeilen, Badges, Live-Indikator.
         Bereich: Präsentation – Designsystem
    ================================================================ -->

    <!-- Goldener Lichtschein hinter Bühnen-Inhalten (Startscreen, Sieger) -->
    <RadialGradientBrush x:Key="GoldSchein">
        <GradientStop Color="{StaticResource FarbeGold500}" Offset="0.0" />
        <GradientStop Color="#00FFC84B" Offset="1.0" />
    </RadialGradientBrush>

    <!-- Schwebende Karte für Anzeige-Inhalte -->
    <Style x:Key="AnzeigeKarteStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource VerlaufKarte}" />
        <Setter Property="BorderBrush" Value="{StaticResource PinselRand}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusL}" />
        <Setter Property="Effect" Value="{StaticResource SchattenKarte}" />
    </Style>

    <!-- Listenzeile der Anzeige (Tabellen, Spielplan) -->
    <Style x:Key="AnzeigeZeileStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PinselFlaecheDunkel}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusM}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <!-- Ergebnis-/Detail-Pille (dunkle Fläche, goldener Inhalt) -->
    <Style x:Key="ErgebnisPilleStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PinselFlaecheDunkel}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusM}" />
        <Setter Property="Padding" Value="24,8" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Spaltenkopf-Text in Anzeige-Tabellen -->
    <Style x:Key="TabellenKopfTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource PinselTextGedaempft}" />
    </Style>

    <!-- Runde Nummern-Plakette (Duellnummer) -->
    <Style x:Key="KreisNummerStyle" TargetType="Border">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPille}" />
        <Setter Property="Background" Value="{StaticResource PinselFlaecheAktiv}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Duellliste: aktive Zeile hervorheben -->
    <Style x:Key="DuellZeileStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusM}" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IstAktiv}" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#33FFC84B" Offset="0" />
                            <GradientStop Color="#11FFC84B" Offset="1" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="{StaticResource PinselAkzent}" />
                <Setter Property="BorderThickness" Value="2" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Stechen-Badge -->
    <Style x:Key="StechenBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PinselStechen}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusPille}" />
        <Setter Property="Padding" Value="20,6" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Effect" Value="{StaticResource GlowRot}" />
    </Style>

    <!-- Platzierungs-Zeile: Sieger hervorheben -->
    <Style x:Key="PlatzierungZeileStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PinselFlaecheDunkel}" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusM}" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IstSieger}" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#44FFC84B" Offset="0" />
                            <GradientStop Color="#11FF9A3D" Offset="1" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="{StaticResource PinselAkzent}" />
                <Setter Property="BorderThickness" Value="2" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Pulsierender LIVE-Punkt (Matchday) -->
    <Style x:Key="LivePunktStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Fill" Value="{StaticResource PinselLive}" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.2" Duration="0:0:0.8" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
