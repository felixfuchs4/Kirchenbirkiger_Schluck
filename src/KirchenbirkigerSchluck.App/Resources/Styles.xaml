<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:KirchenbirkigerSchluck.App.Converters">

    <!-- ================================================================
         Datei:   Styles.xaml
         Zweck:   Globale Styles für Anzeige- und Bedienoberfläche
         Bereich: Präsentation – Ressourcen
    ================================================================ -->

    <!-- Konverter -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    <conv:PfadZuBitmapConverter x:Key="PfadZuBitmap" />
    <conv:PfadZuVisibilityConverter x:Key="PfadZuVisibility" />
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />

    <!-- ════════════════════════════════════════════════════════════════
         FARBEN (Anzeige) – als Color-Ressourcen für Effekte und Verläufe
    ═════════════════════════════════════════════════════════════════ -->

    <Color x:Key="AnzeigeBgTief">#0B0B1A</Color>
    <Color x:Key="AnzeigeBgMitte">#1B1B3A</Color>
    <Color x:Key="AnzeigeBgHell">#2A2150</Color>
    <Color x:Key="AnzeigeAkzentColor">#FFC84B</Color>
    <Color x:Key="AnzeigeAkzent2Color">#FF7A45</Color>
    <Color x:Key="AnzeigeTextColor">#F5F5FA</Color>
    <Color x:Key="AnzeigeTextGedaempftColor">#9090B0</Color>

    <!-- ════════════════════════════════════════════════════════════════
         PINSEL (Anzeige)
    ═════════════════════════════════════════════════════════════════ -->

    <!-- Vollflächiger Hintergrundverlauf: tiefe Mitternachtsfarben, diagonal -->
    <LinearGradientBrush x:Key="AnzeigeHintergrund" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0B0B1A" Offset="0.0" />
        <GradientStop Color="#1B1B3A" Offset="0.55" />
        <GradientStop Color="#241B45" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Goldener Akzent-Verlauf (für Hervorhebungen, Linien, Scores) -->
    <LinearGradientBrush x:Key="AnzeigeAkzentVerlauf" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFD86B" Offset="0.0" />
        <GradientStop Color="#FFC84B" Offset="0.5" />
        <GradientStop Color="#FF9A3D" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Akzentfläche dunkel (für Karten-Header, Score-Bereich) -->
    <LinearGradientBrush x:Key="AnzeigeKopfVerlauf" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#16142E" Offset="0.0" />
        <GradientStop Color="#0C0B1C" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Glas-/Kartenfläche mit leichter Transparenz -->
    <LinearGradientBrush x:Key="AnzeigeKarteVerlauf" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#22203F" Offset="0.0" />
        <GradientStop Color="#191733" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="AnzeigeAkzent" Color="#FFC84B" />
    <SolidColorBrush x:Key="AnzeigeAkzent2" Color="#FF7A45" />
    <SolidColorBrush x:Key="AnzeigeText" Color="#F5F5FA" />
    <SolidColorBrush x:Key="AnzeigeTextGedaempft" Color="#9090B0" />
    <SolidColorBrush x:Key="AnzeigeTrennlinie" Color="#34315E" />
    <SolidColorBrush x:Key="AnzeigeKartenRand" Color="#3A3768" />

    <!-- ════════════════════════════════════════════════════════════════
         EFFEKTE – Glühen und Tiefe
    ═════════════════════════════════════════════════════════════════ -->

    <!-- Goldenes Glühen für Scores und Sieger -->
    <DropShadowEffect x:Key="GoldGlow" Color="#FFC84B" BlurRadius="36"
                      ShadowDepth="0" Opacity="0.75" />

    <!-- Dezentes Glühen für Überschriften -->
    <DropShadowEffect x:Key="GoldGlowSoft" Color="#FFC84B" BlurRadius="18"
                      ShadowDepth="0" Opacity="0.45" />

    <!-- Tiefenschatten für schwebende Karten -->
    <DropShadowEffect x:Key="KartenSchatten" Color="#000000" BlurRadius="28"
                      ShadowDepth="6" Opacity="0.55" Direction="270" />

    <!-- Roter Glüh-Effekt für Stechen -->
    <DropShadowEffect x:Key="RotGlow" Color="#FF4B4B" BlurRadius="24"
                      ShadowDepth="0" Opacity="0.7" />

    <!-- ════════════════════════════════════════════════════════════════
         TEXT-STYLES (Anzeige)
    ═════════════════════════════════════════════════════════════════ -->

    <!-- Großer Score-Text (Matchday-Header) – mit goldenem Glühen -->
    <Style x:Key="ScoreTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="120" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource AnzeigeAkzentVerlauf}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Effect" Value="{StaticResource GoldGlow}" />
    </Style>

    <!-- Team-Name auf Matchday-Screen (groß) -->
    <Style x:Key="TeamNameAnzeigeStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="44" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource AnzeigeText}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- Überschrift Anzeige (z.B. Turniername, Screen-Titel) -->
    <Style x:Key="UeberschriftAnzeigeStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource AnzeigeAkzent}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Effect" Value="{StaticResource GoldGlowSoft}" />
    </Style>

    <!-- Uhrzeit-Anzeige (Startscreen) -->
    <Style x:Key="UhrzeitStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="110" />
        <Setter Property="FontWeight" Value="Thin" />
        <Setter Property="Foreground" Value="{StaticResource AnzeigeText}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="Segoe UI, Consolas" />
    </Style>

    <!-- Normaler Anzeigetext -->
    <Style x:Key="AnzeigeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="Foreground" Value="{StaticResource AnzeigeText}" />
    </Style>

    <!-- Gedämpfter Anzeigetext -->
    <Style x:Key="AnzeigeTextGedaempftStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Foreground" Value="{StaticResource AnzeigeTextGedaempft}" />
    </Style>

    <!-- ════════════════════════════════════════════════════════════════
         KOMPONENTEN (Anzeige)
    ═════════════════════════════════════════════════════════════════ -->

    <!-- Schwebende Karte für Anzeige-Inhalte -->
    <Style x:Key="AnzeigeKarteStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AnzeigeKarteVerlauf}" />
        <Setter Property="BorderBrush" Value="{StaticResource AnzeigeKartenRand}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Effect" Value="{StaticResource KartenSchatten}" />
    </Style>

    <!-- Duellliste: aktive Zeile hervorheben -->
    <Style x:Key="DuellZeileStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Margin" Value="0,3" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IstAktiv}" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#33FFC84B" Offset="0" />
                            <GradientStop Color="#11FFC84B" Offset="1" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="{StaticResource AnzeigeAkzent}" />
                <Setter Property="BorderThickness" Value="2" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Stechen-Badge -->
    <Style x:Key="StechenBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="#D43A2F" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20,6" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Effect" Value="{StaticResource RotGlow}" />
    </Style>

    <!-- Sieger-Hervorhebung (Gewinner-Screen) -->
    <Style x:Key="SiegerHervorhebungStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="84" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource AnzeigeAkzentVerlauf}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="Effect" Value="{StaticResource GoldGlow}" />
    </Style>

    <!-- Platzierungs-Zeile: Sieger hervorheben -->
    <Style x:Key="PlatzierungZeileStyle" TargetType="Border">
        <Setter Property="Background" Value="#1E1B3A" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Margin" Value="0,4" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IstSieger}" Value="True">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#44FFC84B" Offset="0" />
                            <GradientStop Color="#11FF9A3D" Offset="1" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="{StaticResource AnzeigeAkzent}" />
                <Setter Property="BorderThickness" Value="2" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Pulsierender LIVE-Punkt (Matchday) -->
    <Style x:Key="LivePunktStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Fill" Value="#FF4B4B" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.2" Duration="0:0:0.8" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- ════════════════════════════════════════════════════════════════
         BEDIENOBERFLÄCHE
    ═════════════════════════════════════════════════════════════════ -->

    <!-- Nächstes-Spiel-Button (groß, prominent) -->
    <Style x:Key="NaechstesSpielButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="56" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <!-- Versuch-Button (4 Buttons im 2×2-Grid) – groß für schnelle Bedienung -->
    <Style x:Key="VersuchButtonStyle" TargetType="Button"
           BasedOn="{StaticResource MaterialDesignRaisedButton}">
        <Setter Property="Height" Value="72" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

</ResourceDictionary>
